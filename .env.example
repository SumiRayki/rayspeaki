# Copy this file to .env and fill in your values
# cp .env.example .env

# Server passwords (users use SERVER_PASSWORD, admins use ADMIN_PASSWORD)
SERVER_PASSWORD=changeme_server
ADMIN_PASSWORD=changeme_admin

# Database
DB_PASSWORD=rayspeaki_db_pass

# Ports exposed on the host
APP_PORT=4000
API_PORT=3000

# TURN server credentials (clients use these to authenticate with coturn)
TURN_USER=rayspeaki
TURN_CREDENTIAL=rayspeakiturn
TURN_REALM=rayspeaki

# Only set this if automatic IP detection fails (no internet at startup)
# MEDIASOUP_ANNOUNCED_IP=1.2.3.4
